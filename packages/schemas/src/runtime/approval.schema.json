{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://widenote.dev/schemas/runtime_approval.schema.json",
  "title": "WideNote Runtime Approval",
  "description": "Approval request and decision contracts for gated runtime tool actions. Raw tool input is intentionally excluded; approval surfaces record references, summaries, reasons, expiry, and redacted input keys only.",
  "oneOf": [
    {
      "$ref": "#/$defs/approval_request"
    },
    {
      "$ref": "#/$defs/approval_decision"
    }
  ],
  "$defs": {
    "approval_request": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "id",
        "schema_version",
        "status",
        "pack_id",
        "agent_id",
        "task_id",
        "run_id",
        "tool_id",
        "source_refs",
        "action_summary",
        "reason",
        "approval_options",
        "redacted_input_keys",
        "requested_at"
      ],
      "properties": {
        "kind": {
          "const": "approval_request"
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "schema_version": {
          "type": "integer",
          "minimum": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "pending",
            "decided",
            "expired",
            "canceled"
          ]
        },
        "pack_id": {
          "$ref": "#/$defs/pack_id"
        },
        "agent_id": {
          "$ref": "#/$defs/agent_id"
        },
        "task_id": {
          "type": "string",
          "minLength": 1
        },
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "tool_id": {
          "type": "string",
          "minLength": 1
        },
        "source_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/source_ref"
          },
          "uniqueItems": true
        },
        "action_summary": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": [
            "string",
            "null"
          ]
        },
        "approval_options": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/approval_decision_kind"
          },
          "uniqueItems": true
        },
        "expires_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "redacted_input_keys": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "requested_at": {
          "type": "string",
          "format": "date-time"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "approval_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "id",
        "schema_version",
        "request_id",
        "decision",
        "reason",
        "pack_id",
        "agent_id",
        "task_id",
        "run_id",
        "tool_id",
        "source_refs",
        "redacted_input_keys",
        "decided_at"
      ],
      "properties": {
        "kind": {
          "const": "approval_decision"
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "schema_version": {
          "type": "integer",
          "minimum": 1
        },
        "request_id": {
          "type": "string",
          "minLength": 1
        },
        "decision": {
          "$ref": "#/$defs/approval_decision_kind"
        },
        "reason": {
          "type": [
            "string",
            "null"
          ]
        },
        "pack_id": {
          "$ref": "#/$defs/pack_id"
        },
        "agent_id": {
          "$ref": "#/$defs/agent_id"
        },
        "task_id": {
          "type": "string",
          "minLength": 1
        },
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "tool_id": {
          "type": "string",
          "minLength": 1
        },
        "source_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/source_ref"
          },
          "uniqueItems": true
        },
        "redacted_input_keys": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "grant_expires_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "decided_at": {
          "type": "string",
          "format": "date-time"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "approval_decision_kind": {
      "type": "string",
      "enum": [
        "approve_once",
        "deny"
      ]
    },
    "source_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "id"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "event",
            "record",
            "capture",
            "attachment",
            "transcript",
            "memory",
            "card",
            "insight",
            "recap",
            "todo",
            "conversation",
            "message",
            "file",
            "uri",
            "manual"
          ]
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "source_version": {
          "type": [
            "integer",
            "string",
            "null"
          ]
        },
        "content_hash": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "event_id": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "uri": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        }
      }
    },
    "pack_id": {
      "type": "string",
      "pattern": "^pack\\.[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)*$"
    },
    "agent_id": {
      "type": "string",
      "pattern": "^agent\\.[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)*$"
    }
  }
}
