{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://widenote.dev/schemas/backup_export_manifest.schema.json",
  "title": "WideNote Backup And Owner Export Manifest",
  "description": "Manifest contracts for restorable backups and secret-free Owner Export.",
  "oneOf": [
    {
      "$ref": "#/$defs/backup_manifest"
    },
    {
      "$ref": "#/$defs/owner_export_manifest"
    }
  ],
  "$defs": {
    "backup_manifest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "schema_version",
        "format",
        "format_version",
        "backup_mode",
        "includes_secrets",
        "local_db_schema_version",
        "created_at",
        "record_counts"
      ],
      "properties": {
        "kind": {
          "const": "backup_manifest"
        },
        "schema_version": {
          "type": "integer",
          "minimum": 1
        },
        "format": {
          "type": "string",
          "const": "widenote.local_data_backup"
        },
        "format_version": {
          "type": "integer",
          "minimum": 1
        },
        "backup_mode": {
          "type": "string",
          "enum": [
            "safe",
            "encrypted_full"
          ]
        },
        "includes_secrets": {
          "type": "boolean"
        },
        "encryption": {
          "$ref": "#/$defs/encryption_or_null"
        },
        "local_db_schema_version": {
          "type": "integer",
          "minimum": 1
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "record_counts": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "sections": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/section"
          }
        },
        "checksums": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/checksum"
          }
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "owner_export_manifest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "schema_version",
        "format",
        "export_version",
        "created_at",
        "excludes_secrets",
        "derived_outputs_labeled",
        "context_packet_caches_excluded",
        "sections",
        "checksums"
      ],
      "properties": {
        "kind": {
          "const": "owner_export_manifest"
        },
        "schema_version": {
          "type": "integer",
          "minimum": 1
        },
        "format": {
          "type": "string",
          "const": "widenote.owner_export"
        },
        "export_version": {
          "type": "integer",
          "minimum": 1
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "excludes_secrets": {
          "const": true
        },
        "derived_outputs_labeled": {
          "type": "boolean"
        },
        "context_packet_caches_excluded": {
          "type": "boolean"
        },
        "sections": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/section"
          }
        },
        "checksums": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/checksum"
          }
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "section": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "path",
        "record_count"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "record_count": {
          "type": "integer",
          "minimum": 0
        },
        "contains_ai_derived": {
          "type": "boolean"
        },
        "contains_secrets": {
          "type": "boolean"
        },
        "required_for_restore": {
          "type": "boolean"
        },
        "checksum_sha256": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        }
      }
    },
    "checksum": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-fA-F]{64}$"
        }
      }
    },
    "encryption_or_null": {
      "anyOf": [
        {
          "$ref": "#/$defs/encryption"
        },
        {
          "type": "null"
        }
      ]
    },
    "encryption": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scheme",
        "key_derivation"
      ],
      "properties": {
        "scheme": {
          "type": "string",
          "minLength": 1
        },
        "key_derivation": {
          "type": "string",
          "minLength": 1
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}
