{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://widenote.dev/schemas/trace.schema.json",
  "title": "WideNote Trace Event",
  "description": "Audit event for runtime, agent, model, tool, permission, and output behavior.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "schema_version",
    "trace_type",
    "severity",
    "status",
    "created_at"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "trace_type": {
      "type": "string",
      "enum": [
        "run_started",
        "run_completed",
        "task_created",
        "task_waiting",
        "task_blocked",
        "task_canceled",
        "task_retry_queued",
        "event_received",
        "event_emitted",
        "permission_checked",
        "model_called",
        "tool_invoked",
        "tool_denied",
        "approval_requested",
        "approval_decided",
        "error"
      ]
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "level": {
      "description": "Runtime compatibility severity from RuntimeTrace.",
      "type": "string",
      "enum": [
        "debug",
        "info",
        "warning",
        "error"
      ]
    },
    "run_id": {
      "description": "Optional because pre-run runtime traces can be emitted while appending or routing an event.",
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "task_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "pack_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "agent_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "event_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "parent_trace_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "severity": {
      "type": "string",
      "enum": [
        "debug",
        "info",
        "warn",
        "error"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "ok",
        "denied",
        "skipped",
        "error"
      ]
    },
    "run_mode": {
      "$ref": "#/$defs/run_mode"
    },
    "tool_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "tool_access": {
      "$ref": "#/$defs/tool_access_or_null"
    },
    "tool_risk": {
      "$ref": "#/$defs/tool_risk_or_null"
    },
    "tool_locality": {
      "$ref": "#/$defs/tool_locality_or_null"
    },
    "approval_request_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "approval_decision": {
      "$ref": "#/$defs/approval_decision_or_null"
    },
    "message": {
      "type": [
        "string",
        "null"
      ]
    },
    "duration_ms": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    },
    "redacted_payload": {
      "description": "Optional redacted payload projection for trace review. Raw tool input and secret values must not be stored here.",
      "type": "object",
      "additionalProperties": true
    },
    "redaction": {
      "$ref": "#/$defs/redaction"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "run_mode": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "read_only",
        "confirm",
        "auto",
        null
      ]
    },
    "tool_access_or_null": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "read",
        "write",
        "read_write",
        null
      ]
    },
    "tool_risk_or_null": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "low",
        "medium",
        "high",
        null
      ]
    },
    "tool_locality_or_null": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "local",
        "external",
        null
      ]
    },
    "approval_decision_or_null": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "approve_once",
        "deny",
        null
      ]
    },
    "redaction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contains_raw_tool_input",
        "redacted_keys"
      ],
      "properties": {
        "contains_raw_tool_input": {
          "const": false
        },
        "redacted_keys": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "policy": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        }
      }
    }
  }
}
