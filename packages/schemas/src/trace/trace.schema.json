{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://widenote.dev/schemas/trace.schema.json",
  "title": "WideNote Trace Event",
  "description": "Audit event for runtime, agent, model, tool, permission, and output behavior.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "schema_version",
    "trace_type",
    "run_id",
    "severity",
    "status",
    "created_at"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "trace_type": {
      "type": "string",
      "enum": [
        "run_started",
        "run_completed",
        "event_received",
        "event_emitted",
        "permission_checked",
        "model_called",
        "tool_invoked",
        "error"
      ]
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "pack_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "agent_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "event_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "parent_trace_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "severity": {
      "type": "string",
      "enum": [
        "debug",
        "info",
        "warn",
        "error"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "ok",
        "denied",
        "skipped",
        "error"
      ]
    },
    "message": {
      "type": [
        "string",
        "null"
      ]
    },
    "duration_ms": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
