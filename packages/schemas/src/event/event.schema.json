{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://widenote.dev/schemas/event.schema.json",
  "title": "WideNote Event",
  "description": "Append-only runtime event envelope. Event-specific payload schemas can refine the payload field.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "type",
    "schema_version",
    "actor",
    "subject_ref",
    "payload",
    "privacy",
    "device_id",
    "created_at"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "$ref": "#/$defs/event_type"
    },
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "actor": {
      "type": "string",
      "enum": [
        "user",
        "agent",
        "plugin",
        "system"
      ]
    },
    "pack_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "agent_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "subject_ref": {
      "$ref": "#/$defs/subject_ref"
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    },
    "privacy": {
      "type": "string",
      "enum": [
        "local_only",
        "encrypted_sync",
        "remote_allowed"
      ]
    },
    "causation_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "correlation_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "trace_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "idempotency_key": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "device_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "retention": {
      "$ref": "#/$defs/retention"
    },
    "redaction": {
      "$ref": "#/$defs/redaction"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "event_type": {
      "type": "string",
      "pattern": "^wn\\.[a-z][a-z0-9_]*\\.[a-z][a-z0-9_]*$"
    },
    "subject_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "id"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "uri": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        }
      }
    },
    "retention": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "policy": {
          "type": "string",
          "enum": [
            "inherit",
            "keep",
            "expire",
            "delete_with_subject"
          ]
        },
        "expires_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        }
      }
    },
    "redaction": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "policy": {
          "type": "string",
          "enum": [
            "none",
            "redact_payload",
            "redact_subject",
            "redact_all"
          ]
        },
        "reason": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}
