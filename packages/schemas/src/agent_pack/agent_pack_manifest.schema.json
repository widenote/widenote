{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://widenote.dev/schemas/agent_pack_manifest.schema.json",
  "title": "WideNote Agent Pack Manifest",
  "description": "Manifest contract for declarative Agent Packs.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "version",
    "schema_version",
    "publisher",
    "edition",
    "permissions",
    "subscriptions",
    "agents"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "id": {
      "$ref": "#/$defs/pack_id"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:[-+][0-9A-Za-z.-]+)?$"
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "publisher": {
      "type": "string",
      "minLength": 1
    },
    "edition": {
      "type": "string",
      "enum": [
        "official",
        "store",
        "community",
        "local_dev"
      ]
    },
    "description": {
      "type": "string"
    },
    "compatibility": {
      "$ref": "#/$defs/compatibility"
    },
    "marketplace": {
      "$ref": "#/$defs/marketplace"
    },
    "replacement_slots": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/slot_declaration"
      },
      "uniqueItems": true
    },
    "additive_slots": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/slot_declaration"
      },
      "uniqueItems": true
    },
    "entrypoint_kind": {
      "type": "string",
      "enum": [
        "native",
        "declarative",
        "remote",
        "script"
      ]
    },
    "default_run_mode": {
      "$ref": "#/$defs/run_mode"
    },
    "permissions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/permission_id"
      },
      "uniqueItems": true
    },
    "subscriptions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/subscription"
      }
    },
    "agents": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/agent"
      }
    },
    "model_profiles": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/model_profile"
      }
    },
    "tools": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/tool"
      }
    },
    "ui_blocks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ui_block"
      }
    },
    "settings_schema": {
      "type": "object",
      "additionalProperties": true
    },
    "secrets_schema": {
      "type": "object",
      "additionalProperties": true
    },
    "storage_quota": {
      "$ref": "#/$defs/storage_quota"
    },
    "integrity": {
      "$ref": "#/$defs/integrity"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "pack_id": {
      "type": "string",
      "pattern": "^pack\\.[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)*$"
    },
    "agent_id": {
      "type": "string",
      "pattern": "^agent\\.[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)*$"
    },
    "permission_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)+$"
    },
    "event_type": {
      "type": "string",
      "pattern": "^wn\\.[a-z][a-z0-9_]*\\.[a-z][a-z0-9_]*$"
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "widenote_min": {
          "type": "string"
        },
        "widenote_max": {
          "type": [
            "string",
            "null"
          ]
        },
        "schema_version": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "marketplace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "trust_level",
        "categories",
        "capabilities"
      ],
      "properties": {
        "source": {
          "type": "string",
          "enum": [
            "bundled",
            "github",
            "local_dev"
          ]
        },
        "trust_level": {
          "type": "string",
          "enum": [
            "official",
            "reviewed",
            "community",
            "local_dev"
          ]
        },
        "install_mode": {
          "type": "string",
          "enum": [
            "bundled",
            "manifest_url",
            "local_file",
            "deferred"
          ]
        },
        "repository_url": {
          "type": [
            "string",
            "null"
          ]
        },
        "docs_path": {
          "type": [
            "string",
            "null"
          ]
        },
        "icon_path": {
          "type": [
            "string",
            "null"
          ]
        },
        "categories": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/marketplace_tag"
          },
          "uniqueItems": true
        },
        "capabilities": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/marketplace_tag"
          },
          "uniqueItems": true
        },
        "status": {
          "type": "string",
          "enum": [
            "available",
            "preview",
            "deferred",
            "disabled"
          ]
        }
      }
    },
    "slot_declaration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "mode"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/slot_id"
        },
        "mode": {
          "type": "string",
          "enum": [
            "reserved",
            "exclusive",
            "additive"
          ]
        },
        "description": {
          "type": "string"
        }
      }
    },
    "marketplace_tag": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)*$"
    },
    "slot_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)+$"
    },
    "subscription": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "event_types",
        "agent_id"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^sub\\.[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)*$"
        },
        "event_types": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/event_type"
          },
          "uniqueItems": true
        },
        "agent_id": {
          "$ref": "#/$defs/agent_id"
        },
        "delivery": {
          "type": "string",
          "enum": [
            "async",
            "sync"
          ]
        },
        "enabled_by_default": {
          "type": "boolean"
        },
        "depends_on": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^sub\\.[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)*$"
          },
          "uniqueItems": true
        }
      }
    },
    "agent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "runtime",
        "output_events"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/agent_id"
        },
        "runtime": {
          "type": "string",
          "enum": [
            "native",
            "declarative",
            "remote",
            "script"
          ]
        },
        "run_mode": {
          "$ref": "#/$defs/run_mode"
        },
        "name": {
          "type": "string"
        },
        "prompt_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "model_profile_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "permissions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/permission_id"
          },
          "uniqueItems": true
        },
        "tools": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "output_events": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/event_type"
          },
          "uniqueItems": true
        },
        "retry_policy": {
          "$ref": "#/$defs/retry_policy"
        }
      }
    },
    "retry_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_attempts"
      ],
      "properties": {
        "max_attempts": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        }
      }
    },
    "model_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "purpose"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "purpose": {
          "type": "string",
          "minLength": 1
        },
        "required": {
          "type": "boolean"
        },
        "routing_policy": {
          "type": "string",
          "enum": [
            "app_default",
            "user_selected",
            "pack_preferred",
            "fixed_provider"
          ]
        },
        "provider_ref": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "model_ref": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "required_capabilities": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "chat",
              "completion",
              "embedding",
              "vision",
              "audio",
              "streaming",
              "tool_use",
              "toolUse"
            ]
          },
          "uniqueItems": true
        },
        "allow_fallback": {
          "type": "boolean"
        }
      }
    },
    "tool": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "permissions",
        "required_permissions",
        "access",
        "risk",
        "locality",
        "approval_requirement",
        "execution"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "capability_kind": {
          "$ref": "#/$defs/tool_capability_kind"
        },
        "permissions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/permission_id"
          },
          "uniqueItems": true
        },
        "required_permissions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/permission_id"
          },
          "uniqueItems": true
        },
        "access": {
          "$ref": "#/$defs/tool_access"
        },
        "risk": {
          "$ref": "#/$defs/tool_risk"
        },
        "locality": {
          "$ref": "#/$defs/tool_locality"
        },
        "approval_requirement": {
          "$ref": "#/$defs/tool_approval_requirement"
        },
        "execution": {
          "$ref": "#/$defs/tool_execution"
        },
        "side_effect": {
          "type": "string",
          "enum": [
            "none",
            "local_write",
            "external_write",
            "network",
            "model_call",
            "file_access",
            "script_execution"
          ]
        },
        "input_schema": {
          "description": "JSON-schema-like input shape. Do not include raw fixture input values.",
          "type": "object",
          "additionalProperties": true
        },
        "output_schema": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "ui_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "claim_list",
            "metric_row",
            "source_refs",
            "note"
          ]
        },
        "events": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/event_type"
          },
          "uniqueItems": true
        }
      }
    },
    "storage_quota": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "local_bytes": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "integrity": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "checksum_sha256": {
          "type": [
            "string",
            "null"
          ]
        },
        "signature": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "run_mode": {
      "type": "string",
      "enum": [
        "read_only",
        "confirm",
        "auto"
      ]
    },
    "tool_access": {
      "type": "string",
      "enum": [
        "read",
        "write",
        "read_write"
      ]
    },
    "tool_risk": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "tool_locality": {
      "type": "string",
      "enum": [
        "local",
        "external"
      ]
    },
    "tool_approval_requirement": {
      "type": "string",
      "enum": [
        "none",
        "per_call",
        "deferred"
      ]
    },
    "tool_execution": {
      "type": "string",
      "enum": [
        "local",
        "fake",
        "deferred",
        "disabled"
      ]
    },
    "tool_capability_kind": {
      "type": "string",
      "enum": [
        "local_core",
        "context_packet",
        "memory",
        "todo",
        "trace",
        "settings",
        "model",
        "http",
        "mcp",
        "web",
        "file",
        "network",
        "shell",
        "script",
        "runner",
        "webhook"
      ]
    }
  }
}
