{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://widenote.dev/schemas/insight_payload.schema.json",
  "title": "WideNote Insight Payload",
  "description": "Source-linked structured payload for local-first insights. This is derived state and must preserve source refs.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "insight_kind",
    "title",
    "summary",
    "claims",
    "source_refs",
    "ui_blocks",
    "generator",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 2
    },
    "insight_kind": {
      "type": "string",
      "enum": [
        "summary",
        "count",
        "trend",
        "source_mix",
        "action_pattern",
        "attachment_evidence",
        "behavior_loop",
        "contrast",
        "turning_point",
        "question",
        "energy_rhythm",
        "relationship_pattern"
      ]
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "sensitivity": {
      "$ref": "#/$defs/sensitivity"
    },
    "evidence_density": {
      "type": "string",
      "enum": [
        "thin",
        "medium",
        "high"
      ]
    },
    "pattern_window": {
      "$ref": "#/$defs/pattern_window"
    },
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/claim"
      }
    },
    "metrics": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/metric"
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidence_item"
      }
    },
    "counter_evidence": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidence_item"
      }
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/source_ref"
      },
      "uniqueItems": true
    },
    "ui_blocks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/ui_block"
      }
    },
    "review": {
      "$ref": "#/$defs/review"
    },
    "generator": {
      "$ref": "#/$defs/generator"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "note": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "text",
        "source_refs"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "text": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "sensitivity": {
          "$ref": "#/$defs/sensitivity"
        },
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/source_ref"
          },
          "uniqueItems": true
        }
      }
    },
    "metric": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "value"
      ],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "type": "number"
        },
        "unit": {
          "type": "string",
          "minLength": 1
        },
        "source_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/source_ref"
          },
          "uniqueItems": true
        }
      }
    },
    "evidence_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "text",
        "source_refs"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": [
            "supporting",
            "counter",
            "context"
          ]
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "text": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/source_ref"
          },
          "uniqueItems": true
        }
      }
    },
    "source_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "id"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "event",
            "record",
            "capture",
            "attachment",
            "transcript",
            "memory",
            "card",
            "insight",
            "recap",
            "todo",
            "conversation",
            "message",
            "artifact",
            "file",
            "uri",
            "manual"
          ]
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "source_version": {
          "type": [
            "integer",
            "string",
            "null"
          ]
        },
        "content_hash": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "event_id": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "uri": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "excerpt": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "sensitivity": {
          "$ref": "#/$defs/sensitivity_or_null"
        }
      }
    },
    "ui_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "claim_list",
            "metric_row",
            "source_refs",
            "note",
            "evidence_list",
            "counter_evidence",
            "confidence_band",
            "contrast",
            "trend_chart",
            "timeline"
          ]
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "payload": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state"
      ],
      "properties": {
        "state": {
          "type": "string",
          "enum": [
            "auto_write",
            "needs_review",
            "rejected"
          ]
        },
        "risk_flags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "review_reasons": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    },
    "generator": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pack_id",
        "agent_id"
      ],
      "properties": {
        "pack_id": {
          "type": "string",
          "pattern": "^pack\\.[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)*$"
        },
        "agent_id": {
          "type": "string",
          "pattern": "^agent\\.[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)*$"
        },
        "run_id": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "trace_id": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "model_ref": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        }
      }
    },
    "pattern_window": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "starts_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "ends_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "source_count": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "sensitivity": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "sensitivity_or_null": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "low",
        "medium",
        "high",
        null
      ]
    }
  }
}
