  "agents": [
    {
      "id": "agent.todo_loop",
      "runtime": "native",
      "name": "Todo Loop Agent",
      "prompt_ref": null,
      "model_profile_ref": null,
      "permissions": [
        "todo.suggest"
      ],
      "tools": [],
      "output_events": [
        "wn.todo.suggested"
      ],
      "retry_policy": {
        "max_attempts": 2
      }
    }
  ],
  "model_profiles": [],
  "tools": [],
  "ui_blocks": [],
  "storage_quota": {
    "local_bytes": 0
  },
  "integrity": {
    "checksum_sha256": null,
    "signature": null
  },
  "metadata": {
    "status": "draft",
    "source": "packs/official/todo/manifest.json"
  }
}
