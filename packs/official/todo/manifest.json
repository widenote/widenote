{
  "$schema": "../../../packages/schemas/src/agent_pack/agent_pack_manifest.schema.json",
  "id": "pack.todo",
  "name": "Todo Extraction Loop",
  "version": "0.1.0",
  "schema_version": 1,
  "publisher": "widenote",
  "edition": "official",
  "description": "Built-in pack for source-linked todo suggestions.",
  "compatibility": {
    "widenote_min": "0.1.0",
    "widenote_max": null,
    "schema_version": 1
  },
  "marketplace": {
    "source": "bundled",
    "trust_level": "official",
    "install_mode": "bundled",
    "repository_url": "https://github.com/widenote/widenote",
    "docs_path": "packs/official/todo/README.md",
    "icon_path": null,
    "categories": [
      "task",
      "capture"
    ],
    "capabilities": [
      "todo.suggest"
    ],
    "status": "available"
  },
  "entrypoint_kind": "native",
  "permissions": [
    "todo.suggest"
  ],
  "subscriptions": [
    {
      "id": "sub.todo_capture_created",
      "event_types": [
        "wn.capture.created"
      ],
      "agent_id": "agent.todo_loop",
      "delivery": "async",
      "enabled_by_default": true
    }
